# apps/mattermost/Dockerfile -- Mattermost Team Edition server
#
# We do NOT build Mattermost from source. The upstream Go server + JS
# webapp build chain is ~30 min on a clean machine, requires Postgres
# bootstrap, and produces an artifact byte-identical to the official
# Docker Hub image at the release tag. Per RUNBOOK.md "Known risks",
# building from source was the W3 cost-overrun risk; using the pinned
# official multi-arch image is the documented mitigation.
#
# Upstream image: mattermost/mattermost-team-edition
#   Release tag    : release-11.8
#   Multi-arch idx : sha256:a603c831151383f7fca707a2c7b5e52a1c9b7833de55a02ce59dd1c64667cce1
#   linux/amd64    : sha256:204b98d6f09fff2b957607d7750b1105d200b6c0ae6315912908d57aa0c2704e
#   Pushed (UTC)   : 2026-06-05T11:14:50Z
#   Source SHA     : mattermost/mattermost @ release-11.8 branch HEAD at build time
#                    (see https://github.com/mattermost/mattermost/tree/release-11.8)
#
# To move the pin: bump the digest below to the new multi-arch index sha
# (NOT a moving tag), bump the docker-compose.yml image: line in lockstep,
# bump pinned_image_digest in injection-points.yaml, and re-verify
# selectors against the new build before merging.
#
# This Dockerfile exists primarily to (a) document the pin in version
# control, (b) bake in the non-secret bootstrap config we need for
# headless first-run, and (c) provide a single buildable target so the
# bring-up sequence in RUNBOOK.md is `docker compose build` for symmetry
# with the Conduit reference template.

FROM mattermost/mattermost-team-edition@sha256:a603c831151383f7fca707a2c7b5e52a1c9b7833de55a02ce59dd1c64667cce1

# Non-secret bootstrap env. JWT-equivalent secrets (SiteURL signing key,
# encryption-at-rest key) are auto-generated by Mattermost on first run
# and persisted in the bind-mounted /mattermost/config volume. We do NOT
# inject production secrets here; this image is for screenshot capture
# only and is never exposed beyond the local docker network.
ENV MM_SERVICESETTINGS_SITEURL="http://localhost:8065"
ENV MM_SERVICESETTINGS_ENABLELOCALMODE="true"
ENV MM_SERVICESETTINGS_LISTENADDRESS=":8065"
ENV MM_SERVICESETTINGS_ENABLEDEVELOPER="false"
ENV MM_SERVICESETTINGS_ALLOWCORSFROM="*"
ENV MM_TEAMSETTINGS_ENABLETEAMCREATION="true"
ENV MM_TEAMSETTINGS_ENABLEOPENSERVER="true"
ENV MM_TEAMSETTINGS_ENABLEUSERCREATION="true"
ENV MM_EMAILSETTINGS_REQUIREEMAILVERIFICATION="false"
ENV MM_EMAILSETTINGS_SENDEMAILNOTIFICATIONS="false"
ENV MM_LOGSETTINGS_CONSOLELEVEL="WARN"
ENV MM_PLUGINSETTINGS_ENABLE="false"

# Healthcheck: /api/v4/system/ping returns 200 once the server has
# finished schema migration and is accepting requests. We use a 60s
# start_period because cold-start with empty Postgres takes ~25-40s
# while the server runs initial migrations + creates the bot user.
HEALTHCHECK --interval=10s --timeout=3s --start-period=60s --retries=10 \
  CMD curl -fsS http://localhost:8065/api/v4/system/ping || exit 1

EXPOSE 8065
