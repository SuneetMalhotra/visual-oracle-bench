{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": false,
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "verbatimModuleSyntax": false
  },
  "include": [
    "injection/**/*.ts",
    "capture/**/*.ts",
    "oracles/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts"
  ]
}
